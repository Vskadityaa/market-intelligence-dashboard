# API Keys (optional - app works with yfinance without keys)
# Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# Get free key: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# LLM for summarization and AI Score (OpenAI-compatible)
# Use OpenAI or any OpenAI-compatible endpoint (e.g. Azure, local LLM)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
